NODE_ENV=development
PORT=3001

# 쉼표로 구분. 프로덕션: https://sajumoon.kr,https://mng.sajumoon.kr
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# DB
# DATABASE_URL=postgresql://postgres:password@localhost:5432/sajumoon
# LEGACY_DATABASE_URL=postgresql://postgres:password@localhost:5432/sajumoon_db

# 관리자 인증 (JWT). 운영 배포 시 반드시 교체
# openssl rand -hex 64
ADMIN_JWT_SECRET=change-me-please-use-openssl-rand-hex-64
ADMIN_JWT_EXPIRES_IN=8h
ADMIN_COOKIE_NAME=sjm_admin
# https 배포 시 true
COOKIE_SECURE=false
