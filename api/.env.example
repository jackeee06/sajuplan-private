# ============================================================
# 사주문 API .env (예시)
# ============================================================
# 단일 플래그 SAJUMOON_ENV 한 곳에서만 도메인 결정 (test|prod).
# PG_*, USER_SITE_URL, API_PUBLIC_URL, CORS_ORIGINS, COOKIE_SECURE 등은
# api/src/shared/env/runtime-env.ts 가 자동 도출. .env 에 적지 않는다.
#
#   SAJUMOON_ENV=test → sajumoon.kr     계열 (테스트 서버)
#   SAJUMOON_ENV=prod → sajumoon.co.kr  계열 (운영 서버)
# ============================================================

SAJUMOON_ENV=test

NODE_ENV=development
PORT=3001

# DB
DATABASE_URL=postgresql://USER:PASS@HOST:5432/sajumoon
LEGACY_DATABASE_URL=postgresql://USER:PASS@HOST:5432/sajumoon_db

# 관리자 인증 (JWT). 운영 배포 시 반드시 교체 (openssl rand -hex 64)
ADMIN_JWT_SECRET=change-me-please-use-openssl-rand-hex-64
ADMIN_JWT_EXPIRES_IN=8h
ADMIN_COOKIE_NAME=sjm_admin

# 사용자 인증 (JWT)
USER_JWT_SECRET=change-me-please-use-openssl-rand-hex-64
USER_JWT_EXPIRES_IN=14d
USER_COOKIE_NAME=sjm_user

# m2net (passcall) — 외부 API 키 (환경 무관)
M2NET_API_URL=http://passcall.co.kr:25205
M2NET_CPID=0047
M2NET_HEADER_KEY=f58cdy2sXhkOdp2YSJUjuqEJB

# AG9 PG — 결제 (환경 무관, 동일 키)
AG9_HOST=https://passcall.co.kr:32837
AG9_AUTH_TOKEN=f58cdy2sXhkOdp2YSJUjuqEJB
AG9_CPID=0047
CARD_CRYPT_KEY=pGXygBXTMNNuRJzC

# FCM
FCM_CREDENTIALS_PATH=./secrets/fcm-service-account.json

# 월별 정산 cron 인증 토큰
CRON_TOKEN=change-me-use-openssl-rand-hex-32
