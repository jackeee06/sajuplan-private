<?xml version="1.0" encoding="utf-8"?>
<!--
  Override of react-native-bootsplash's compat_splash_screen.xml.

  Layered approach:
   1. Solid black background (#000000) — 사주플랜 로고의 검정 배경과 일치.
   2. The 3000x3000 splash bitmap, centered at native pixel size (no scale).

  Bitmap이 어떤 단말 폭보다 커서 가운데가 그대로 노출되고,
  외곽 영역은 동일한 검정으로 이어져 경계선 없이 풀스크린으로 보인다.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android" android:opacity="opaque">
    <item android:gravity="fill">
        <shape android:shape="rectangle">
            <solid android:color="#000000" />
        </shape>
    </item>
    <item android:gravity="fill">
        <bitmap
            android:src="@drawable/bootsplash_logo"
            android:gravity="center" />
    </item>
</layer-list>
