<resources>
    <!--
      Android 12+ uses the system Splash Screen API which shows this color
      as the full-screen background BEFORE bootsplash's Dialog overlay can
      take over. Match it to the top of the splash artwork (light purple)
      so there's no visible white seam at the status bar / before the
      gradient image fades in.
    -->
    <color name="bootsplash_background">#AC90FF</color>
</resources>
