<resources>
    <!--
      Android 12+ uses the system Splash Screen API which shows this color
      as the full-screen background BEFORE bootsplash's Dialog overlay can
      take over. Match it to the splash artwork (black) so there's no
      visible white seam at the status bar before the bitmap fades in.
    -->
    <color name="bootsplash_background">#000000</color>
</resources>
